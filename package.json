{
  "name": "hipay-qa-test",
  "version": "1.0.0",
  "description": "HiPay QA technical test – test strategy and E2E automation using CodeceptJS and Gherkin",
  "main": "index.js",
  "scripts": {
    "test": "codeceptjs run --steps",
    "test:allure": "codeceptjs run --steps && allure generate allure-results --clean -o allure-report && allure open allure-report",
    "test:debug": "codeceptjs run --debug",
    "test:feature": "codeceptjs run tests/contact.feature"
  },
