  "devDependencies": {
    "@cucumber/cucumber": "^12.7.0",
    "@eslint/js": "^10.0.1",
    "allure-codeceptjs": "^3.6.0",
    "allure-commandline": "^2.37.0",
    "codeceptjs": "^3.7.6",
    "eslint": "^10.0.3",
    "globals": "^17.4.0",
    "playwright": "^1.58.2"
  }
